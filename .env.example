# DotX Solar Forecast API - environment configuration
#
# 1. Copy this file to `.env` (which is in .gitignore - never commit it).
# 2. Fill in your tenant API key provided by DotX.
# 3. Fill in EMS_API_BASE with the API base URL provided by DotX.
#
# The path to your measurements CSV is set in the CONFIGURATION block at
# the top of `quickstart.py` (and in the first code cell of the notebook),
# not here - it's a per-run knob, not a secret.

EMS_API_KEY=
EMS_API_BASE=
